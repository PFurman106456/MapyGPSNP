<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui8"
             x:Class="MapyGPSNP.MainPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <mapsui:MapControl x:Name="mojaMapa" Grid.Row="0"/>

        <StackLayout Grid.Row="0" Orientation="Vertical"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Margin="8" Spacing="4">
            <Button Text="+" WidthRequest="48" HeightRequest="48"
                    FontSize="22" FontAttributes="Bold"
                    Clicked="btnZoomIn_Clicked"/>
            <Button Text="−" WidthRequest="48" HeightRequest="48"
                    FontSize="22" FontAttributes="Bold"
                    Clicked="btnZoomOut_Clicked"/>
        </StackLayout>


        <Grid Grid.Row="0" x:Name="overlayLadowania" IsVisible="False">
            <BoxView Color="Black" Opacity="0.45"/>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                <ActivityIndicator x:Name="spinner" IsRunning="False" Color="White"
                                   WidthRequest="48" HeightRequest="48"/>
                <Label Text="Wyznaczanie trasy..." TextColor="White"
                       HorizontalOptions="Center" FontSize="14"/>
            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label x:Name="lblOpisTrasy"
                   Text="Gotowy do drogi"
                   Margin="10"
                   VerticalOptions="Center"/>

            <HorizontalStackLayout Grid.Column="1">
                <Button Text="📍"
                        x:Name="btnCentrujStart"
                        Clicked="btnCentrujStart_Clicked"
                        WidthRequest="50"
                        ToolTipProperties.Text="Centruj na punkcie startowym"/>
                <Button
                    Text="Szukaj"
                    x:Name="btnSzukaj"
                    Clicked="btnSzukaj_Clicked"/>
                <Button
                    Text="JEDŹ"
                    x:Name="btnJedz"
                    Clicked="btnJedz_Clicked_1"/>
            </HorizontalStackLayout>
        </Grid>

    </Grid>

</ContentPage>
