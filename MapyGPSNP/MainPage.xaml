<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui8"
             x:Class="MapyGPSNP.MainPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <mapsui:MapControl x:Name="mojaMapa" Grid.Row="0"/>

        <StackLayout Orientation="Vertical" HorizontalOptions="End" VerticalOptions="Start">
            <Button Text="+" WidthRequest="50" HeightRequest="50" FontAttributes="Bold"/>
            <Button Text="-" WidthRequest="50" HeightRequest="50" FontAttributes="Bold"/>
        </StackLayout>

        <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
            
            <Label x:Name="lblOpisTrasy"
                   Text="Gotowy do drogi"
                   Margin="10"
                   VerticalOptions="Center"/>

            <HorizontalStackLayout Grid.Column="1">
                
            <Button 
        Text="Szukaj"
        x:Name="btnSzukaj"
        Clicked="btnSzukaj_Clicked"/>

            <Button
                    Text="JEDŹ"
                    x:Name="btnJedz"
                    Clicked="btnJedz_Clicked"/>
            </HorizontalStackLayout>
            </Grid>

    

    </Grid>

</ContentPage>
