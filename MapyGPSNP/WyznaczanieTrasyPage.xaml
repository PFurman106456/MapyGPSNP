<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MapyGPSNP.WyznaczanieTrasyPage"
             Title="Szukaj trasy">
    <VerticalStackLayout Padding="20" Spacing="10">

        <Label Text="Punkt startowy" FontAttributes="Bold" FontSize="16"/>

        <Label Text="Szerokość geograficzna (lat):"/>
        <Entry x:Name="entryStartLat"
               Placeholder="np. 53.1235"
               Keyboard="Numeric"/>

        <Label Text="Długość geograficzna (lon):"/>
        <Entry x:Name="entryStartLon"
               Placeholder="np. 18.0084"
               Keyboard="Numeric"/>

        <BoxView HeightRequest="1" Color="Gray" Margin="0,10"/>

        <Label Text="Punkt docelowy" FontAttributes="Bold" FontSize="16"/>

        <Label Text="Szerokość geograficzna (lat):"/>
        <Entry x:Name="entryMetaLat"
               Placeholder="np. 54.6094"
               Keyboard="Numeric"/>

        <Label Text="Długość geograficzna (lon):"/>
        <Entry x:Name="entryMetaLon"
               Placeholder="np. 18.8012"
               Keyboard="Numeric"/>

        <Label x:Name="lblBlad" TextColor="Red" IsVisible="False"/>

        <Button Text="Wyznacz trasę"
                x:Name="btnWyznacz"
                Clicked="btnWyznacz_Clicked"
                Margin="0,10"/>

    </VerticalStackLayout>
</ContentPage>
